# Beacon Live — Environment Variables

# Supabase project (Edge Function handles all upstream API calls)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_WEATHER_BACKEND_URL=/api

# Local realtime backend
WEATHER_SOURCE_MODE=real
WEATHER_POLL_MS=20000
WEATHER_HEARTBEAT_MS=15000
METEOFRANCE_KEY=
WINDSUP_USER=
WINDSUP_PASS=
WUNDERGROUND_API_KEY=

VITE_INFOCLIMAT_TOKEN=your_token_here

# --- Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ---
# WU_API_KEY=your-weather-underground-api-key
# METEOFRANCE_KEY=your-meteofrance-api-key
# WINDSUP_USER=your-windsup-username
# WINDSUP_PASS=your-windsup-password
